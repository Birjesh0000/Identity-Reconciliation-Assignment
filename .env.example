# ============================================
# Identity Reconciliation Backend
# Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env file to git

# ============================================
# Server Configuration
# ============================================
# Port on which the server will run
# Default: 8000
PORT=8000

# Node environment (development, production, test)
# development: Shows detailed error messages and debug logs
# production: Hides error details, optimized performance
# Default: development
NODE_ENV=development

# ============================================
# MongoDB Configuration
# ============================================
# MongoDB connection URI string
# Format: mongodb://[username:password@]host[:port]/database
#
# Examples:
# - Local development: mongodb://localhost:27017/identity-reconciliation
# - MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/identity-reconciliation
# - Docker: mongodb://mongodb:27017/identity-reconciliation
#
# IMPORTANT: 
# - Ensure MongoDB is running before starting the server
# - Database will be created automatically if it doesn't exist
MONGODB_URI=mongodb://localhost:27017/identity-reconciliation

# ============================================
# Logging Configuration (Optional)
# ============================================
# Debug mode for detailed request/response logging
# Values: true/false
# Default: false
DEBUG=false

# ============================================
# CORS Configuration (Optional)
# ============================================
# Allowed origins for CORS requests
# Separate multiple origins with commas
# Examples: http://localhost:3000,http://localhost:5000
CORS_ORIGIN=*

# ============================================
# Database Optimization (Optional)
# ============================================
# Connection pool size
DB_POOL_SIZE=10

# Query timeout in milliseconds
QUERY_TIMEOUT=30000

